title  = "Cluster"
)
cat("\nAll tests in testing_sparse_gcPCA.R completed.\n")
## ------------------------------------------------------------
## End of script
## ------------------------------------------------------------
# testing just the regular gcPCA function
standard_gcPCA <- gcPCA(Ra = A, Rb = B, method = "v4", normalize_flag = FALSE)
# plot
idx_plot   <- 1:400
Ra_plot    <- standard_gcPCA$Ra_scores[idx_plot, , drop = FALSE]
cols <- c("black", "red", "darkgreen", "blue")
plot(
Ra_plot[, 1], Ra_plot[, 2],
col  = cols[sub_group_labels],
pch  = 19,
xlab = "Standard gcPCA component 1",
ylab = "Standard gcPCA component 2",
main = sprintf("Standard gcPCA (method = %s, lambda index = %d)", method_used, idx_test)
)
legend(
"topright",
legend = levels(sub_group_labels),
col    = cols,
pch    = 19,
bty    = "n",
title  = "Cluster"
)
# now plot the predict
scores_transform <- predict(standard_gcPCA, Ra = A, Rb = B)
L_j <- standard_gcPCA$loadings[, 1:2, drop = FALSE]
ylim_load <- range(L_j, finite = TRUE)
Ra_plot    <- scores_transform$Ra_scores[idx_plot, , drop = FALSE]
cols <- c("black", "red", "darkgreen", "blue")
par(
mfrow = c(1, 3),
mar = c(2.2, 2.2, 1.8, 0.8),
oma = c(1.6, 1.6, 2.2, 0.8),
mgp = c(1.4, 0.4, 0),
tcl = -0.2,
cex.axis = 0.8,
cex.lab = 0.85,
cex.main = 0.85
)
plot(
Ra_plot[, 1], Ra_plot[, 2],
col  = cols[sub_group_labels],
pch  = 19,
xlab = "Standard gcPCA component 1",
ylab = "Standard gcPCA component 2",
main = sprintf("standard gcPCA (method = %s)", method_used)
)
legend(
"topright",
legend = levels(sub_group_labels),
col    = cols,
pch    = 19,
bty    = "n",
title  = "Cluster"
)
# plotting the loadings for the standard gcPCA
plot(
seq_len(n_feat), L_j[, 1],
type = "h",
lwd  = 2,
xlab = "Feature",
ylab = "Loading",
ylim = ylim_load,
main = "Loadings: comp 1"
)
abline(h = 0, lty = 2, col = "gray50")
plot(
seq_len(n_feat), L_j[, 2],
type = "h",
lwd  = 2,
xlab = "Feature",
ylab = "Loading",
ylim = ylim_load,
main = "Loadings: comp 2"
)
abline(h = 0, lty = 2, col = "gray50")
# now plot sparse predict + sparse loadings across all lambda indices
lambda_indices <- seq_along(lasso_penalty)
n_lambda <- length(lambda_indices)
n_feat <- nrow(sgc_fit$sparse_loadings[[1]])
stopifnot(ncol(sgc_fit$sparse_loadings[[1]]) >= 2)
all_loadings <- do.call(rbind, lapply(
sgc_fit$sparse_loadings,
function(L) cbind(L[, 1], L[, 2])
))
ylim_load <- range(all_loadings, finite = TRUE)
old_par <- par(no.readonly = TRUE)
on.exit(par(old_par), add = TRUE)
# Plot in pages to avoid "figure margins too large" on small devices.
device_height_in <- par("din")[2]
rows_per_page <- max(1L, min(n_lambda, floor(device_height_in / 1.8)))
rows_per_page <- min(rows_per_page, 4L)
n_pages <- ceiling(n_lambda / rows_per_page)
for (page_idx in seq_len(n_pages)) {
page_start <- (page_idx - 1L) * rows_per_page + 1L
page_end <- min(page_idx * rows_per_page, n_lambda)
idx_page <- lambda_indices[page_start:page_end]
n_rows_page <- length(idx_page)
par(
mfrow = c(n_rows_page, 3),
mar = c(2.2, 2.2, 1.8, 0.8),
oma = c(1.6, 1.6, 2.2, 0.8),
mgp = c(1.4, 0.4, 0),
tcl = -0.2,
cex.axis = 0.8,
cex.lab = 0.85,
cex.main = 0.85
)
for (j in idx_page) {
Ra_plot <- pred_AB$Ra_transform[[j]][idx_plot, , drop = FALSE]
L_j <- sgc_fit$sparse_loadings[[j]]
plot(
Ra_plot[, 1], Ra_plot[, 2],
col  = cols[sub_group_labels],
pch  = 19,
xlab = "Comp 1",
ylab = "Comp 2",
main = sprintf("lambda[%d]=%.3g", j, lasso_penalty[j])
)
if (j == idx_page[1]) {
legend(
"topright",
legend = levels(sub_group_labels),
col    = cols,
pch    = 19,
bty    = "n",
cex    = 0.7,
title  = "Cluster"
)
}
plot(
seq_len(n_feat), L_j[, 1],
type = "h",
lwd  = 2,
xlab = "Feature",
ylab = "Loading",
ylim = ylim_load,
main = "Loadings: comp 1"
)
abline(h = 0, lty = 2, col = "gray50")
plot(
seq_len(n_feat), L_j[, 2],
type = "h",
lwd  = 2,
xlab = "Feature",
ylab = "Loading",
ylim = ylim_load,
main = "Loadings: comp 2"
)
abline(h = 0, lty = 2, col = "gray50")
}
mtext(
sprintf("Sparse gcPCA across lambda values (page %d/%d)", page_idx, n_pages),
side = 3, outer = TRUE, line = 0.4
)
}
## ------------------------------------------------------------
## testing_sparse_gcPCA.R
## Test script for sparse_gcPCA + predict.sparse_gcPCA
## Compatible with sparse_gcPCA.R and predict.sparse_gcPCA()
## you provided.
## ------------------------------------------------------------
set.seed(0)
## ------------------------------------------------------------
## 0. Load gcPCA and sparse_gcPCA implementations
## ------------------------------------------------------------
## Adjust these paths as needed
path_gcpca   <- "C:/Users/fermi/Documents/github/generalized_contrastive_PCA/R/gcPCA.R"
path_sparse  <- "C:/Users/fermi/Documents/github/generalized_contrastive_PCA/R/sparse_gcPCA.R"
stopifnot(file.exists(path_gcpca))
stopifnot(file.exists(path_sparse))
source(path_gcpca)
source(path_sparse)
cat("Successfully sourced gcPCA.R and sparse_gcPCA.R\n")
## ------------------------------------------------------------
## 1. Generate toy data (Abid-style example)
## ------------------------------------------------------------
N   <- 4000
D   <- 30
gap <- 3
# Background B
B <- matrix(0, nrow = N, ncol = D)
B[, 1:10]  <- rnorm(N * 10, mean = 0, sd = 10)
B[, 11:20] <- rnorm(N * 10, mean = 0, sd = 3)
B[, 21:30] <- rnorm(N * 10, mean = 0, sd = 1)
# Target A with 4 clusters in dimensions 11:30
A <- matrix(0, nrow = N, ncol = D)
A[, 1:10]  <- rnorm(N * 10, mean = 0, sd = 10)
# group 1
A[1:100,  11:20] <- rnorm(100 * 10, mean = 0,    sd = 1)
A[1:100,  21:30] <- rnorm(100 * 10, mean = 0,    sd = 1)
# group 2
A[101:200, 11:20] <- rnorm(100 * 10, mean = 0,   sd = 1)
A[101:200, 21:30] <- rnorm(100 * 10, mean = gap, sd = 1)
# group 3
A[201:300, 11:20] <- rnorm(100 * 10, mean = 2 * gap, sd = 1)
A[201:300, 21:30] <- rnorm(100 * 10, mean = 0,       sd = 1)
# group 4
A[301:400, 11:20] <- rnorm(100 * 10, mean = 2 * gap, sd = 1)
A[301:400, 21:30] <- rnorm(100 * 10, mean = gap,     sd = 1)
sub_group_labels <- factor(rep(1:4, each = 100))
cat("Generated toy data: A, B are", dim(A)[1], "x", dim(A)[2], "matrices\n")
## ------------------------------------------------------------
## 2. Fit sparse_gcPCA (normalize_flag = FALSE)
## ------------------------------------------------------------
# Lambda grid similar to Python script
lasso_penalty <- c(0, exp(seq(log(1e-5), log(1e-1), length.out = 9)))
Nsparse       <- 2
method_used   <- "v4"
sparse_time <- system.time({
sgc_fit <- sparse_gcPCA(
Ra             = A,
Rb             = B,
method         = method_used,
Ncalc          = NULL,          # default: number of columns
normalize_flag = FALSE,
Nsparse        = Nsparse,
Nshuffle       = 0,
lasso_penalty  = lasso_penalty,
ridge_penalty  = 1e-5,
alpha          = 4,
alpha_null     = 0.975,
tol            = 1e-5,
max_steps      = 1000,
cond_number    = 1e8
)
})
cat("\n--- sparse_gcPCA (normalize_flag = FALSE) ---\n")
cat("Elapsed time:\n")
print(sparse_time)
## ------------------------------------------------------------
## 3. Sanity checks for sparse_gcPCA object
## ------------------------------------------------------------
stopifnot(inherits(sgc_fit, "sparse_gcPCA"))
cat("\nChecking structure of sparse_gcPCA object...\n")
# sparse_loadings: list, one element per lambda
stopifnot(is.list(sgc_fit$sparse_loadings))
stopifnot(length(sgc_fit$sparse_loadings) == length(lasso_penalty))
cat("Number of sparse loading sets:", length(sgc_fit$sparse_loadings), "\n")
# Give names to sparse_loadings (purely for debugging / convenience)
names(sgc_fit$sparse_loadings) <- paste0("lambda_", seq_along(sgc_fit$sparse_loadings))
cat("Names of sparse loadings:\n")
print(names(sgc_fit$sparse_loadings))
# Each loading matrix should be D x Nsparse with (approximately) unit column 2-norm
for (j in seq_along(sgc_fit$sparse_loadings)) {
L <- sgc_fit$sparse_loadings[[j]]
stopifnot(is.matrix(L))
stopifnot(nrow(L) == D)
stopifnot(ncol(L) == Nsparse)
col_norms <- apply(L, 2, function(x) sqrt(sum(x^2)))
if (max(abs(col_norms - 1)) > 1e-6) {
warning(sprintf("Column norms of sparse_loadings[[%d]] deviate from 1 (max diff = %g)",
j, max(abs(col_norms - 1))))
}
}
cat("All sparse loading matrices have shape", D, "x", Nsparse, "and ~unit column norms.\n")
## ------------------------------------------------------------
## 4. Test predict.sparse_gcPCA with new Ra and Rb (no normalization)
## ------------------------------------------------------------
cat("\nTesting predict.sparse_gcPCA with new Ra = A and Rb = B (normalize_flag = FALSE)...\n")
pred_AB <- predict(sgc_fit, Ra = A, Rb = B)
# Structure checks
stopifnot(is.list(pred_AB))
stopifnot(all(c("Ra_scores", "Rb_scores") %in% names(pred_AB)))
stopifnot(is.list(pred_AB$Ra_scores))
stopifnot(is.list(pred_AB$Rb_scores))
stopifnot(length(pred_AB$Ra_scores) == length(lasso_penalty))
stopifnot(length(pred_AB$Rb_scores) == length(lasso_penalty))
# Check dimensions and equality with manual projections for a chosen lambda index
idx_test <- 5
cat("Using lambda index", idx_test, "for detailed checks.\n")
# Ra
Ra_pred  <- pred_AB$Ra_scores[[idx_test]]
L_test   <- sgc_fit$sparse_loadings[[idx_test]]
Ra_manual <- A %*% L_test
stopifnot(all(dim(Ra_pred) == dim(Ra_manual)))
max_diff_Ra <- max(abs(Ra_pred - Ra_manual))
cat("Max diff (Ra_pred vs A %*% L_test):", max_diff_Ra, "\n")
stopifnot(max_diff_Ra < 1e-6)
# Rb
Rb_pred  <- pred_AB$Rb_scores[[idx_test]]
Rb_manual <- B %*% L_test
stopifnot(all(dim(Rb_pred) == dim(Rb_manual)))
max_diff_Rb <- max(abs(Rb_pred - Rb_manual))
cat("Max diff (Rb_pred vs B %*% L_test):", max_diff_Rb, "\n")
stopifnot(max_diff_Rb < 1e-6)
cat("predict() with new Ra/Rb matches manual matrix multiplication for lambda index", idx_test, "\n")
## ------------------------------------------------------------
## 5. Test predict() on a subset of rows (Ra only)
## ------------------------------------------------------------
cat("\nTesting predict() on a subset of rows of A...\n")
idx_subset <- 1:50
A_sub      <- A[idx_subset, , drop = FALSE]
pred_A_sub <- predict(sgc_fit, Ra = A_sub)
stopifnot(is.list(pred_A_sub$Ra_scores))
stopifnot(length(pred_A_sub$Ra_scores) == length(lasso_penalty))
Ra_sub_pred   <- pred_A_sub$Ra_scores[[idx_test]]
Ra_sub_manual <- A_sub %*% L_test
stopifnot(all(dim(Ra_sub_pred) == dim(Ra_sub_manual)))
max_diff_sub <- max(abs(Ra_sub_pred - Ra_sub_manual))
cat("Max diff (subset Ra_pred vs A_sub %*% L_test):", max_diff_sub, "\n")
stopifnot(max_diff_sub < 1e-6)
cat("Subset predict() check passed.\n")
## ------------------------------------------------------------
## 6. Simple 2D scatter plot of sparse gcPCA scores
## ------------------------------------------------------------
cat("\nGenerating 2D scatter plot of Ra_scores (first 2 columns) for first 400 samples...\n")
idx_plot   <- 1:400
Ra_plot    <- pred_AB$Ra_scores[[idx_test]][idx_plot, , drop = FALSE]
cols <- c("black", "red", "darkgreen", "blue")
plot(
Ra_plot[, 1], Ra_plot[, 2],
col  = cols[sub_group_labels],
pch  = 19,
xlab = "Sparse gcPCA component 1",
ylab = "Sparse gcPCA component 2",
main = sprintf("sparse gcPCA (method = %s, lambda index = %d)", method_used, idx_test)
)
legend(
"topright",
legend = levels(sub_group_labels),
col    = cols,
pch    = 19,
bty    = "n",
title  = "Cluster"
)
cat("\nAll tests in testing_sparse_gcPCA.R completed.\n")
## ------------------------------------------------------------
## End of script
## ------------------------------------------------------------
# testing just the regular gcPCA function
standard_gcPCA <- gcPCA(Ra = A, Rb = B, method = "v4", normalize_flag = FALSE)
# plot
idx_plot   <- 1:400
Ra_plot    <- standard_gcPCA$Ra_scores[idx_plot, , drop = FALSE]
cols <- c("black", "red", "darkgreen", "blue")
