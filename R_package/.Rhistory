old_par <- par(no.readonly = TRUE)
on.exit(par(old_par), add = TRUE)
# Plot in pages to avoid "figure margins too large" on small devices.
device_height_in <- par("din")[2]
rows_per_page <- max(1L, min(n_lambda, floor(device_height_in / 1.8)))
rows_per_page <- min(rows_per_page, 4L)
n_pages <- ceiling(n_lambda / rows_per_page)
for (page_idx in seq_len(n_pages)) {
